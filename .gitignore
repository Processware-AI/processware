# ==========================================
# macOS
# ==========================================
.DS_Store
._*
.Spotlight-V100
.Trashes

# ==========================================
# 고객 입력자료 (저작권·기밀)
# 실데이터는 제외, 구조·README 만 버전 관리
# _scaffold 는 전체 추적 (템플릿)
# ==========================================

# 전사 공통: 실데이터 제외, 구조만 추적
/vault/_inputs_common/**
!/vault/_inputs_common/
!/vault/_inputs_common/README.md
!/vault/_inputs_common/*/
!/vault/_inputs_common/*/README.md

# 표준별: 실데이터 제외, 구조만 추적
/vault/02_표준/*/_inputs/**
!/vault/02_표준/*/_inputs/
!/vault/02_표준/*/_inputs/README.md
!/vault/02_표준/*/_inputs/*/
!/vault/02_표준/*/_inputs/*/README.md

# Scaffold 는 전체 추적 (위 패턴 무효화)
!/vault/02_표준/_scaffold/**

# ==========================================
# 파이프라인 실행 상태 (인스턴스별)
# ==========================================
vault/02_표준/**/_state*.yaml
vault/02_표준/**/99_QA리포트_*.md
vault/02_표준/**/02_작업노트.md

# ==========================================
# Obsidian 워크스페이스 (개인 환경)
# ==========================================
.obsidian/workspace*
.obsidian/cache/
.obsidian/appearance.json
.obsidian/hotkeys.json

# ==========================================
# 환경·로그·임시
# ==========================================
*.log
*.tmp
.env
.env.local
.env.*.local
*.swp
*.swo

# ==========================================
# Claude Code 세션 캐시 (로컬만)
# ==========================================
.claude/sessions/
.claude/cache/

# ==========================================
# 의존성·빌드 (향후 프레임워크화 대비)
# ==========================================
node_modules/
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
