# ==========================================
# macOS
# ==========================================
.DS_Store
._*
.Spotlight-V100
.Trashes

# ==========================================
# 고객 입력자료 (저작권·기밀)
# 실데이터는 제외, 구조·README 만 버전 관리
# ==========================================

# sources/ — ingest 소스 파일 (PDF·DOCX 등, 저작권/기밀)
/sources/**
!/sources/
!/sources/README.md

# inputs/ — ingest 출력 패키지 (YAML·MD 만, 바이너리 금지)
/inputs/**
!/inputs/
!/inputs/README.md
!/inputs/*/
!/inputs/*/README.md
!/inputs/*/*.yaml
!/inputs/*/*.md
!/inputs/*/*/
!/inputs/*/*/*.yaml
!/inputs/*/*/*.md

# 02_적용요건 하위 실데이터 제외 (README만 추적)
!/vault/02_적용요건/
!/vault/02_적용요건/README.md

# ==========================================
# 파이프라인 실행 상태 (인스턴스별)
# ==========================================
.claude/states/*.yaml
vault/02_적용요건/**/99_QA리포트_*.md

# ==========================================
# Obsidian 워크스페이스 (개인 환경)
# ==========================================
.obsidian/workspace*
.obsidian/cache/
.obsidian/appearance.json
.obsidian/hotkeys.json

# ==========================================
# 환경·로그·임시
# ==========================================
*.log
*.tmp
.env
.env.local
.env.*.local
*.swp
*.swo

# ==========================================
# Claude Code 세션 캐시 (로컬만)
# ==========================================
.claude/sessions/
.claude/cache/

# ==========================================
# 차원 2 (Do) 실행 캐시 — 재생성 가능
# `.claude/runs/` 는 감사 증적이므로 추적
# ==========================================
vault/05_WI_업무지침/.cache/

# ==========================================
# 의존성·빌드 (향후 프레임워크화 대비)
# ==========================================
node_modules/
__pycache__/
*.pyc
.venv/
venv/
dist/
build/
